<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>SaaSApp.Api</RootNamespace>
    <AssemblyName>SaaSApp.Api</AssemblyName>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- API-only: no Razor views; avoids CS9057 when VS Roslyn (4.8) lags SDK Razor analyzer (4.9). -->
    <EnableDefaultRazorCompileItems>false</EnableDefaultRazorCompileItems>
    <NoWarn>$(NoWarn);1591;9057</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.11">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.Data.SqlClient" Version="5.2.2" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="8.0.11" />
    <PackageReference Include="Microsoft.Extensions.Caching.StackExchangeRedis" Version="8.0.11" />
    <PackageReference Include="MediatR" Version="12.4.1" />
    <PackageReference Include="Azure.Storage.Blobs" Version="12.22.2" />
    <PackageReference Include="Hangfire.AspNetCore" Version="1.8.14" />
    <PackageReference Include="Hangfire.SqlServer" Version="1.8.14" />
    <PackageReference Include="Microsoft.Identity.Web" Version="3.0.0" />
    <PackageReference Include="System.IdentityModel.Tokens.Jwt" Version="8.2.1" />
    <PackageReference Include="Otp.NET" Version="1.4.1" />
    <PackageReference Include="BCrypt.Net-Next" Version="4.0.3" />
    <PackageReference Include="Serilog.AspNetCore" Version="8.0.3" />
    <PackageReference Include="Serilog.Sinks.ApplicationInsights" Version="4.0.0" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\BuildingBlocks\Catalog\SaaSApp.Catalog.csproj" />
    <ProjectReference Include="..\BuildingBlocks\Logging\SaaSApp.Logging.csproj" />
    <ProjectReference Include="..\BuildingBlocks\MultiTenancy\SaaSApp.MultiTenancy.csproj" />
    <ProjectReference Include="..\BuildingBlocks\Security\SaaSApp.Security.csproj" />
    <ProjectReference Include="..\Modules\Users\Users.Application\SaaSApp.Users.Application.csproj" />
    <ProjectReference Include="..\Modules\Users\Users.Infrastructure\SaaSApp.Users.Infrastructure.csproj" />
    <ProjectReference Include="..\Modules\Billing\Billing.Application\SaaSApp.Billing.Application.csproj" />
    <ProjectReference Include="..\Modules\Billing\Billing.Infrastructure\SaaSApp.Billing.Infrastructure.csproj" />
    <ProjectReference Include="..\Modules\Reporting\Reporting.Application\SaaSApp.Reporting.Application.csproj" />
    <ProjectReference Include="..\Modules\Reporting\Reporting.Infrastructure\SaaSApp.Reporting.Infrastructure.csproj" />
    <ProjectReference Include="..\Modules\Workflow\Workflow.Application\SaaSApp.Workflow.Application.csproj" />
    <ProjectReference Include="..\Modules\Workflow\Workflow.Infrastructure\SaaSApp.Workflow.Infrastructure.csproj" />
    <ProjectReference Include="..\Modules\Dms\Dms.Infrastructure\SaaSApp.Dms.Infrastructure.csproj" />
    <ProjectReference Include="..\Modules\Repository\Repository.Application\SaaSApp.Repository.Application.csproj" />
    <ProjectReference Include="..\Modules\Repository\Repository.Infrastructure\SaaSApp.Repository.Infrastructure.csproj" />
    <ProjectReference Include="..\Modules\ActivityLog\ActivityLog.Application\SaaSApp.ActivityLog.Application.csproj" />
    <ProjectReference Include="..\Modules\ActivityLog\ActivityLog.Infrastructure\SaaSApp.ActivityLog.Infrastructure.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="..\..\scripts\CreatePlaygroundApiKeySchema.sql">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>scripts\CreatePlaygroundApiKeySchema.sql</Link>
    </None>
    <None Update="..\..\scripts\CreatePlaygroundApiKeyCatalog.sql">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>scripts\CreatePlaygroundApiKeyCatalog.sql</Link>
    </None>
    <None Update="..\..\scripts\CreateWorkflowSchemaComplete.sql">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>scripts\CreateWorkflowSchemaComplete.sql</Link>
    </None>
    <None Update="..\..\scripts\CreateDmsSchema.sql">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>scripts\CreateDmsSchema.sql</Link>
    </None>
    <None Update="..\..\scripts\Create-Connector-Table.sql">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>scripts\Create-Connector-Table.sql</Link>
    </None>
    <None Update="..\..\scripts\Create-EmailIngest-Tables.sql">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>scripts\Create-EmailIngest-Tables.sql</Link>
    </None>
    <None Update="appsettings.ActivityLog.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </None>
    <None Update="appsettings.EventLog.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </None>
    <EmbeddedResource Include="..\..\scripts\CreateWorkflowSchemaComplete.sql" Link="CreateWorkflowSchemaComplete.sql" />
    <EmbeddedResource Include="..\..\scripts\CreateDmsSchema.sql" Link="CreateDmsSchema.sql" />
  </ItemGroup>

</Project>
